{
  "name": "strict-check",
  "version": "0.0.0",
  "description": "This is the monorepo that management the package for static analysis.",
  "keywords": [
    "eslint",
    "eslint-config",
    "eslint-plugin",
    "eslintconfig",
    "eslintplugin",
    "strict-check"
  ],
  "author": "akky-xxxx",
  "repository": {
    "type": "git",
    "url": "https://github.com/akky-xxxx/strict-check"
  },
  "bugs": "https://github.com/akky-xxxx/strict-check/issues",
  "homepage": "https://github.com/akky-xxxx/strict-check",
  "license": "MIT",
  "scripts": {
    "check-code": "run-p lint spell-check",
    "fix": "run-p \"fix:*\" -c",
    "fix:eslint": "eslint \"./\" --fix --max-warnings 0",
    "fix:pack": "fixpack",
    "fix:prettier": "prettier \".\" \"!{dry-run,modules,packages}/**\" -w -u",
    "lint": "run-p \"lint:*\" -c",
    "lint:eslint": "eslint \"./\" --max-warnings 0",
    "lint:pack": "fixpack --dryRun",
    "lint:prettier": "prettier \".\" \"!{dry-run,modules,packages}/**\" -c -u",
    "postinstall": "run-s \"postinstall:*\"",
    "postinstall:copy-shared": "node ./scripts/copy-shared/index.js",
    "postinstall:dependence-build": "pnpm -r run build",
    "postinstall:husky": "pnpm husky",
    "spell-check": "cspell lint --no-progress \"./{config,scripts}/**/*.{js,mjs}\" \"./*.{js,mjs}\"",
    "ws-check-code": "pnpm -r run check-code",
    "ws-dev": "pnpm -r run dev",
    "ws-fix": "pnpm -r run fix",
    "ws-lint": "pnpm -r run lint",
    "ws-spell-check": "pnpm -r run spell-check",
    "ws-test": "pnpm -r run test",
    "ws-type-check": "pnpm -r run type-check"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^10.0.1",
    "@tsconfig/strictest": "^2.0.5",
    "@types/node": "^25.8.0",
    "@types/react": "19.2.14",
    "cspell": "^10.0.0",
    "eslint": "^9.30.0",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fixpack": "^4.0.0",
    "husky": "^9.1.7",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "typescript-eslint": "^8.59.3"
  },
  "workspaces": [
    "dry-run/*",
    "modules/*",
    "packages/*"
  ],
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
