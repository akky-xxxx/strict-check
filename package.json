{
  "name": "strict-check",
  "version": "0.0.0",
  "description": "This is the monorepo that management the package for static analysis.",
  "keywords": [
    "eslint",
    "eslint-config",
    "eslint-plugin",
    "eslintconfig",
    "eslintplugin",
    "strict-check"
  ],
  "author": "akky-xxxx",
  "repository": {
    "type": "git",
    "url": "https://github.com/akky-xxxx/strict-check"
  },
  "bugs": "https://github.com/akky-xxxx/strict-check/issues",
  "homepage": "https://github.com/akky-xxxx/strict-check",
  "license": "MIT",
  "scripts": {
    "check-code": "run-p lint spell-check",
    "fix": "run-p \"fix:*\" -c",
    "fix:eslint": "eslint \"./\" --fix --max-warnings 0",
    "fix:pack": "fixpack",
    "fix:prettier": "prettier \"./*.json\" \"./**/*.json\" !\"./dry-run/**/*\" !\"./modules/**/*\" !\"./packages/**/*\" -w -u",
    "lint": "run-p \"lint:*\" -c",
    "lint:eslint": "eslint \"./\" --max-warnings 0",
    "lint:pack": "fixpack --dryRun",
    "lint:prettier": "prettier \"./*.json\" \"./**/*.json\" !\"./dry-run/**/*\" !\"./modules/**/*\" !\"./packages/**/*\" -c -u",
    "postinstall": "run-s \"postinstall:*\"",
    "postinstall:copy-shared": "node ./scripts/copy-shared/index.js",
    "postinstall:dependence-build": "pnpm -r --if-present run build",
    "postinstall:husky": "pnpm husky",
    "spell-check": "cspell lint --no-progress \"./{config,scripts}/**/*.{js,mjs}\" \"./*.{js,mjs}\"",
    "ws-check-code": "pnpm -r --if-present run check-code",
    "ws-dev": "pnpm -r --if-present run dev",
    "ws-fix": "pnpm -r --if-present run fix",
    "ws-lint": "pnpm -r --if-present run lint",
    "ws-spell-check": "pnpm -r --if-present run spell-check",
    "ws-test": "pnpm -r --if-present run test",
    "ws-type-check": "pnpm -r --if-present run type-check"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.30.0",
    "@stylistic/eslint-plugin": "^5.1.0",
    "@types/react": "19.1.8",
    "cspell": "^9.1.2",
    "eslint": "^9.30.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.32.0",
    "fixpack": "^4.0.0",
    "husky": "^9.1.7",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.6.2"
  },
  "workspaces": [
    "dry-run/*",
    "modules/*",
    "packages/*"
  ],
  "packageManager": "pnpm@9.12.2"
}
