{
  "name": "dr-eslint-config-sc-next",
  "scripts": {
    "bootstrap": "run-p \"bootstrap:*\"",
    "bootstrap:copy-shared": "node ../../scripts/copy-shared/index.js",
    "bootstrap:dependence-build": "pnpm -r run build",
    "check-code": "run-p lint dry-run",
    "dry-run": "run-p \"dry-run:*\" -c",
    "dry-run:flat-jsx": "eslint -c tests/eslint.config.jsx.mjs \"tests/flat/*.jsx\" --max-warnings 0",
    "dry-run:flat-tsx": "eslint -c tests/eslint.config.tsx.mjs \"tests/flat/*.tsx\" --max-warnings 0",
    "fix": "run-p \"fix:*\" -c",
    "fix:pack": "fixpack",
    "fix:prettier": "prettier \".\" --ignore-path ../../.prettierignore -w -u",
    "lint": "run-p \"lint:*\" -c",
    "lint:pack": "fixpack --dryRun",
    "lint:prettier": "prettier \".\" --ignore-path ../../.prettierignore -c -u"
  },
  "devDependencies": {
    "@typescript-eslint/parser": "^8.59.3",
    "eslint": "^9.30.0",
    "eslint-config-sc-next": "workspace:^",
    "eslint-config-sc-ts": "workspace:^",
    "fixpack": "^4.0.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3"
  }
}
