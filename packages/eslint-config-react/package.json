{
  "name": "eslint-config-sc-react",
  "version": "0.2.0",
  "description": "Strict Check config for eslint for react",
  "keywords": [
    "eslint",
    "eslint-config",
    "eslintconfig",
    "react",
    "strict-check"
  ],
  "author": "akky-xxxx",
  "repository": {
    "type": "git",
    "url": "https://github.com/akky-xxxx/strict-check"
  },
  "bugs": "https://github.com/akky-xxxx/strict-check/issues",
  "homepage": "https://strict-check-series.pages.dev/packages/eslint-config-sc-react",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "bootstrap": "run-p \"bootstrap:*\"",
    "bootstrap:copy-shared": "node ../../scripts/copy-shared/index.js",
    "bootstrap:dependence-build": "pnpm -r run build",
    "build": "run-s \"build:*\"",
    "build:1": "rm -rf ./dist",
    "build:2": "tsc -p tsconfig.build.json",
    "check-code": "npm-run-all -c -s bootstrap -p lint spell-check type-check -s dry-run",
    "dry-run": "run-s dry-run:prepare dry-run:exec",
    "dry-run:exec": "pnpm --filter dr-eslint-config-sc-react run dry-run",
    "dry-run:prepare": "pnpm --filter dr-eslint-config-sc-react run bootstrap",
    "fix": "run-p \"fix:*\" -c",
    "fix:eslint": "eslint \"./\" --fix --max-warnings 0",
    "fix:pack": "fixpack",
    "fix:prettier": "prettier \".\" --ignore-path ../../.prettierignore -w -u",
    "lint": "run-p \"lint:*\" -c",
    "lint:eslint": "eslint \"./\" --max-warnings 0",
    "lint:pack": "fixpack --dryRun",
    "lint:prettier": "prettier \".\" --ignore-path ../../.prettierignore -c -u",
    "publish:dry-run": "npm pack --dry-run",
    "spell-check": "cspell lint --no-progress \"./{spec,src}/**/*.ts\" \"./{config,scripts}/**/*.{js,mjs}\" \"./*.{js,mjs}\"",
    "tagging": "node ../../scripts/tagging/index.mjs",
    "type-check": "tsc"
  },
  "dependencies": {
    "globals": "^17.6.0"
  },
  "devDependencies": {
    "@tsconfig/strictest": "^2.0.5",
    "@types/react": "^19.2.14",
    "@typescript-eslint/parser": "^8.59.3",
    "chokidar-cli": "^3.0.0",
    "cspell": "^10.0.0",
    "eslint": "^9.30.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-sc-js": "workspace:^",
    "eslint-config-sc-ts": "workspace:^",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "fixpack": "^4.0.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.6.2",
    "react": "^19.1.0",
    "strict-check": "workspace:^",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "eslint-config-sc-js": ">=0.1.3 <1",
    "eslint-config-sc-ts": ">=0.1.2 <1",
    "eslint-plugin-jsx-a11y": ">=6.10.2"
  },
  "packageManager": "pnpm@10.11.0"
}
