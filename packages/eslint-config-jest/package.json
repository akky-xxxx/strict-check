{
  "name": "eslint-config-sc-jest",
  "version": "0.1.3",
  "description": "Strict Check config for eslint for jest",
  "keywords": [
    "eslint",
    "eslint-config",
    "eslintconfig",
    "jest",
    "strict-check"
  ],
  "author": "akky-xxxx",
  "repository": {
    "type": "git",
    "url": "https://github.com/akky-xxxx/strict-check"
  },
  "bugs": "https://github.com/akky-xxxx/strict-check/issues",
  "homepage": "https://strict-check-series.pages.dev/packages/eslint-config-sc-jest",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "run-s \"build:*\"",
    "build:1": "rm -rf ./dist",
    "build:2": "tsc -p tsconfig.build.json",
    "check-code": "npm-run-all -c -s prepare -p lint spell-check type-check -s dry-run",
    "dev": "chokidar \"./{src,dry-run}/**\" -c \"pnpm type-check && pnpm dry-run\"",
    "dry-run": "run-s dry-run:prepare dry-run:exec",
    "dry-run:exec": "pnpm --filter dr-eslint-config-sc-jest run dry-run",
    "dry-run:prepare": "pnpm --filter dr-eslint-config-sc-jest run prepare",
    "fix": "run-p \"fix:*\" -c",
    "fix:eslint": "eslint \"./\" --fix --max-warnings 0",
    "fix:pack": "fixpack",
    "fix:prettier": "prettier \".\" --ignore-path ../../.gitignore -w -u",
    "lint": "run-p \"lint:*\" -c",
    "lint:eslint": "eslint \"./\" --max-warnings 0",
    "lint:pack": "fixpack --dryRun",
    "lint:prettier": "prettier \".\" --ignore-path ../../.gitignore -c -u",
    "prepare": "run-p \"prepare:*\"",
    "prepare:copy-shared": "node ../../scripts/copy-shared/index.js",
    "prepare:dependence-build": "pnpm -r run build",
    "publish:dry-run": "npm pack --dry-run",
    "spell-check": "cspell lint --no-progress \"./{spec,src}/**/*.ts\" \"./{config,scripts}/**/*.{js,mjs}\" \"./*.{js,mjs}\"",
    "tagging": "node ../../scripts/tagging/index.mjs",
    "type-check": "tsc"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.30.0",
    "@tsconfig/strictest": "^2.0.5",
    "@typescript-eslint/eslint-plugin": "^8.35.1",
    "@typescript-eslint/parser": "^8.35.1",
    "chokidar-cli": "^3.0.0",
    "cspell": "^9.1.2",
    "eslint": "^9.30.0",
    "fixpack": "^4.0.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.6.2",
    "strict-check": "workspace:^",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1"
  },
  "peerDependencies": {
    "eslint-plugin-jest": ">=29.0.1"
  },
  "packageManager": "pnpm@10.11.0"
}
