{
  "name": "eslint-config-sc-ts",
  "version": "0.1.3",
  "description": "Strict Check config for eslint for typescript",
  "keywords": [
    "eslint",
    "eslint-config",
    "eslintconfig",
    "strict-check",
    "typescript"
  ],
  "author": "akky-xxxx",
  "repository": {
    "type": "git",
    "url": "https://github.com/akky-xxxx/strict-check"
  },
  "bugs": "https://github.com/akky-xxxx/strict-check/issues",
  "homepage": "https://strict-check-series.pages.dev/packages/eslint-config-sc-ts",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "run-s \"build:*\"",
    "build:1": "rm -rf ./dist",
    "build:2": "tsc -p tsconfig.build.json",
    "check-code": "npm-run-all -c -p lint spell-check type-check -s dry-run",
    "dev": "chokidar \"./{src,dry-run}/**\" -c \"pnpm type-check && pnpm dry-run\"",
    "dry-run": "run-s dry-run:exec",
    "dry-run:exec": "pnpm -F dr-eslint-config-sc-ts run dry-run",
    "fix": "run-p \"fix:*\" -c",
    "fix:eslint": "eslint \"./\" --fix --max-warnings 0",
    "fix:pack": "fixpack",
    "fix:prettier": "prettier \"./*.json\" \"./**/*.json\" --ignore-path ../../.gitignore -w -u",
    "lint": "run-p \"lint:*\" -c",
    "lint:eslint": "eslint \"./\" --max-warnings 0",
    "lint:pack": "fixpack --dryRun",
    "lint:prettier": "prettier \"./*.json\" \"./**/*.json\" --ignore-path ../../.gitignore -c -u",
    "publish:dry-run": "npm pack --dry-run",
    "spell-check": "cspell lint --no-progress \"./{spec,src}/**/*.ts\" \"./{config,scripts}/**/*.{js,mjs}\" \"./*.{js,mjs}\"",
    "tagging": "node ../../scripts/tagging/index.mjs",
    "type-check": "tsc"
  },
  "devDependencies": {
    "@stylistic/eslint-plugin": "^5.1.0",
    "@tsconfig/strictest": "^2.0.5",
    "chokidar-cli": "^3.0.0",
    "cspell": "^9.1.2",
    "eslint": "^9.30.0",
    "fixpack": "^4.0.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.6.2",
    "strict-check": "workspace:^",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1"
  },
  "peerDependencies": {
    "@eslint/eslintrc": ">=3.3.1",
    "@eslint/js": ">=9.30.0",
    "eslint-config-sc-js": ">=0.1.3",
    "eslint-import-resolver-typescript": ">=4.4.4",
    "typescript-eslint": ">=8.35.1"
  }
}
